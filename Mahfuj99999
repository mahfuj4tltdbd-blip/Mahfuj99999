const express = require("express");
const axios = require("axios");
const fs = require("fs");

const app = express();
app.use(express.json());

// ===== BOT TOKEN =====
const TOKEN = "8664574970:AAE0_lLLeDYfynDrrYw15cBGNw11o_6TWIA";
const API = `https://api.telegram.org/bot${TOKEN}`;

// ===== OWNER =====
const OWNER = "6079418217";
const adminPass = "794082";

// ===== SMS API =====
let apiLink =
  "https://mahirvai.com/sms.php?key=AMвЂ“MRXRPSh2PU&number=01XXXXXXXX&msg=XXXX";

// ===== JSON FILES =====
if (!fs.existsSync("users.json"))
  fs.writeFileSync("users.json", "{}");

if (!fs.existsSync("state.json"))
  fs.writeFileSync("state.json", "{}");

if (!fs.existsSync("codes.json"))
  fs.writeFileSync("codes.json", "{}");

if (!fs.existsSync("ban.json"))
  fs.writeFileSync("ban.json", "{}");

// ===== LOAD =====
let users = JSON.parse(fs.readFileSync("users.json"));
let state = JSON.parse(fs.readFileSync("state.json"));
let codes = JSON.parse(fs.readFileSync("codes.json"));
let banned = JSON.parse(fs.readFileSync("ban.json"));

// ===== SAVE =====
function saveAll() {
  fs.writeFileSync("users.json", JSON.stringify(users, null, 2));
  fs.writeFileSync("state.json", JSON.stringify(state, null, 2));
  fs.writeFileSync("codes.json", JSON.stringify(codes, null, 2));
  fs.writeFileSync("ban.json", JSON.stringify(banned, null, 2));
}

// ===== SEND =====
async function send(id, text, keyboard = null) {
  try {
    await axios.post(`${API}/sendMessage`, {
      chat_id: id,
      text,
      parse_mode: "Markdown",
      reply_markup: keyboard
        ? {
            keyboard,
            resize_keyboard: true,
          }
        : undefined,
    });
  } catch (e) {
    console.log(e.message);
  }
}

// ===== HOME =====
function home(id) {
  state[id] = {
    page: "home",
  };

  if (!users[id]) {
    users[id] = {
      coin: 0,
      lastBonus: 0,
    };
  }

  saveAll();

  send(id, "рџ‘‡ Please Select Your Choice", [
    ["рџ“Ё Send Custom Sms"],
    ["рџЋЃ Gift Coin", "рџ’Њ Redeem Code"],
    ["рџ‘¤ My Account"],
    ["рџЋ‰ Bonus", "рџ‘Ґ Admin Panel"],
  ]);
}

// ===== ADMIN MENU =====
function adminMenu(id) {
  state[id] = {
    page: "admin_menu",
  };

  saveAll();

  send(id, "вњ… Admin Panel", [
    ["рџ‘¤ User List"],
    ["рџЋџ Generate Code"],
