// ===== WEBHOOK =====
app.post("/", async (req, res) => {
  res.sendStatus(200);

  const msg = req.body.message;

  if (!msg || !msg.text) return;

  const id = msg.chat.id.toString();
  const text = msg.text.trim();

  // ===== DEFAULT =====
  if (!users[id]) {
    users[id] = {
      coin: 0,
      lastBonus: 0,
    };
  }

  if (!state[id]) {
    state[id] = {};
  }

  // ===== START =====
  if (text === "/start") {
    return home(id);
  }

  // ===== BACK =====
  if (text === "Back") {
    return goBack(id);
  }

  // ===== BAN CHECK =====
  if (
    id !== OWNER &&
    banned[id] &&
    Date.now() < banned[id]
  ) {
    return send(id, "в›” You are banned for 24 hours");
  }

  // ===== ADMIN PANEL =====
  if (text === "рџ‘Ґ Admin Panel") {
    state[id] = {
      step: "admin_pass",
      page: "admin_login",
    };

    saveAll();

    return send(id, "рџ”ђ Enter Admin Password:", [
      ["Back"],
    ]);
  }

  // ===== ADMIN PASSWORD =====
  if (state[id].step === "admin_pass") {
    if (text !== adminPass) {
      if (id !== OWNER) {
        banned[id] =
          Date.now() + 24 * 60 * 60 * 1000;

        state[id] = {};
      }

      saveAll();

      return send(
        id,
        "вќЊ Wrong Password\nрџљ« Banned 24 Hours"
      );
    }

    return adminMenu(id);
  }

  // ===== USER LIST =====
  if (
    state[id].page === "admin_menu" &&
    text === "рџ‘¤ User List"
  ) {
    let list = Object.keys(users)
      .map(
        (u) => `${u} = ${users[u].coin} Coin`
      )
      .join("\n");

    return send(
      id,
      list || "No users",
      [["Back"]]
    );
  }

  // ===== UNUSED CODES =====
  if (
    state[id].page === "admin_menu" &&
    text === "рџ“¦ Unused Codes"
  ) {
    let list = Object.keys(codes)
      .filter((c) => !codes[c].used)
      .map(
        (c) =>
          `${c} = ${codes[c].coin} Coin`
      )
      .join("\n");

    state[id].page = "unused";

    saveAll();

    return send(
      id,
      list || "No unused code",
      [["Back"]]
    );
  }

  // ===== GENERATE CODE =====
  if (
    state[id].page === "admin_menu" &&
    text === "рџЋџ Generate Code"
  ) {
    state[id] = {
      page: "gen_code",
    };

    saveAll();

    return send(id, "Enter Coin Amount:", [
      ["Back"],
    ]);
  }

  if (state[id].page === "gen_code") {
    let amount = parseInt(text);

    if (!amount || amount <= 0) {
      return send(id, "вќЊ Invalid Amount");
    }

    let code =
      "TABASSUM-" +
      Math.random()
        .toString(36)
        .substring(2, 6)
        .toUpperCase();

    codes[code] = {
      coin: amount,
      used: false,
    };

    state[id] = {
      page: "admin_menu",
    };

    saveAll();

    return send(
      id,
      `вњ… Code Generated

\`${code}\`

рџ’° Coin: ${amount}`,
      [["Back"]]
    );
  }

  // ===== REDEEM =====
  if (text === "рџ’Њ Redeem Code") {
    state[id] = {
      step: "redeem",
      page: "redeem",
    };

    saveAll();

    return send(id, "Enter Code:", [
      ["Back"],
    ]);
  }

  if (state[id].step === "redeem") {
    let c = codes[text];

    if (!c) {
      return send(id, "вќЊ Invalid Code");
    }

    if (c.used) {
      return send(id, "вќЊ Already Used");
    }

    users[id].coin += c.coin;
    c.used = true;

    state[id] = {};

    saveAll();

    return send(
      id,
      `вњ… ${c.coin} Coin Added`
    );
  }

  // ===== GIFT =====
  if (text === "рџЋЃ Gift Coin") {
    if (users[id].coin <= 0) {
      return send(id, "вќЊ No Coin");
    }

    state[id] = {
      step: "gift",
      page: "gift",
    };

    saveAll();

    return send(id, "Enter Coin Amount:", [
      ["Back"],
    ]);
  }

  if (state[id].step === "gift") {
    let amount = parseInt(text);

    if (!amount || amount <= 0) {
      return send(id, "вќЊ Invalid Amount");
    }

    if (users[id].coin < amount) {
      return send(
        id,
        "вќЊ Not Enough Coin"
      );
    }

    users[id].coin -= amount;

    let code =
      "TABASSUM-" +
      Math.random()
        .toString(36)
        .substring(2, 6)
        .toUpperCase();

    codes[code] = {
      coin: amount,
      used: false,
    };

    state[id] = {};

    saveAll();

    return send(
      id,
      `рџЋЃ YOUR CODE

\`${code}\`

рџ’° Coin: ${amount}`
    );
  }

  // ===== ACCOUNT =====
  if (text === "рџ‘¤ My Account") {
    return send(
      id,
      `рџ‘¤ ID: ${id}
рџ’° Balance: ${users[id].coin}`
    );
  }

  // ===== BONUS =====
  if (text === "рџЋ‰ Bonus") {
    let now = Date.now();

    if (
      now - users[id].lastBonus <
      86400000
    ) {
      return send(
        id,
        "вЏі Already Claimed"
      );
    }

    users[id].lastBonus = now;
    users[id].coin += 1;

    saveAll();

    return send(id, "рџЋ‰ Bonus Added");
  }

  // ===== SMS =====
  if (text === "рџ“Ё Send Custom Sms") {
    state[id] = {
      step: "num",
      page: "sms",
    };

    saveAll();

    return send(id, "Enter Number:", [
      ["Back"],
    ]);
  }

  // ===== NUMBER =====
  if (state[id].step === "num") {
    state[id].number = text;
    state[id].step = "msg";

    saveAll();

    return send(id, "Enter Message:", [
      ["Back"],
    ]);
  }

  // ===== MESSAGE =====
  if (state[id].step === "msg") {
    if (users[id].coin <= 0) {
      return send(id, "вќЊ No Coin");
    }

    let url = apiLink
      .replace(
        "01XXXXXXXX",
        state[id].number
      )
      .replace(
        "XXXX",
        encodeURIComponent(text)
      );

    try {
      await axios.get(url);

      users[id].coin--;

      state[id] = {};

      saveAll();

      return send(id, "вњ… SMS Sent");
    } catch {
      return send(
        id,
        "вќЊ API Error"
      );
    }
  }
});

